<html><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"></head><body><div style="background: var(--color-background-secondary); padding: 1.5rem; border-radius: var(--border-radius-lg);">
  <p style="font-size: 12px; color: var(--color-text-secondary); margin: 0 0 12px; font-weight: 500;">STEP 3 — Create a password</p>
  <div style="background: #0d1117; border-radius: var(--border-radius-lg); padding: 40px 20px; display: flex; flex-direction: column; align-items: center; gap: 16px;">
    <svg height="40" viewBox="0 0 16 16" width="40" fill="white"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
    <p style="font-size: 24px; font-weight: 500; color: white; margin: 0;">Create a password</p>
    <div style="width: 100%; max-width: 320px;">
      <label style="font-size: 12px; font-weight: 500; color: #8b949e; display: block; margin-bottom: 6px;">Create a password *</label>
      <input type="password" value="mypassword123" readonly="" style="width: 100%; box-sizing: border-box; padding: 9px 12px; font-size: 14px; border-radius: 6px; border: 2px solid #238636; background: #161b22; color: white;">
      <p style="font-size: 11px; color: #8b949e; margin: 6px 0 0;">Use 15+ characters, or 8+ with a number and a lowercase letter.</p>
    </div>
    <div style="width: 100%; max-width: 320px;">
      <p style="font-size: 12px; color: #8b949e; margin: 0 0 5px;">Password strength</p>
      <div style="display: flex; gap: 4px;">
        <div style="flex:1; height:4px; border-radius:2px; background:#238636;"></div>
        <div style="flex:1; height:4px; border-radius:2px; background:#238636;"></div>
        <div style="flex:1; height:4px; border-radius:2px; background:#238636;"></div>
        <div style="flex:1; height:4px; border-radius:2px; background:#30363d;"></div>
      </div>
      <p style="font-size: 11px; color: #238636; margin: 4px 0 0;">Strong</p>
    </div>
    <button style="width: 100%; max-width: 320px; padding: 10px; font-size: 14px; font-weight: 500; border-radius: 6px; border: none; background: #238636; color: white; cursor: pointer;">Continue →</button>
  </div>
</div>
</body></html>